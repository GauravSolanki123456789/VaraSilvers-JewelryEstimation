# --- SERVER CONFIG ---
PORT=3001
NODE_ENV=production
COMPANY_NAME="Your Company Name"
APP_TAGLINE="Estimations & Inventory"

# --- DATABASE ---
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/jewelry_varasilvers?sslmode=disable
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=jewelry_varasilvers

# --- GOOGLE AUTH (optional — leave blank for password-only desktop installs) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLIENT_URL=http://localhost:3001
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# --- SUPER ADMIN (password login uses admin_users table + this email) ---
SUPER_ADMIN_EMAIL=jaigaurav56789@gmail.com

# --- SECURITY ---
SESSION_SECRET=change_this_to_a_long_random_string
