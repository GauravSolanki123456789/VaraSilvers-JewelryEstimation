{
  "name": "jewelry-estimation",
  "version": "2.5.0",
  "description": "Single-Tenant Jewelry Estimation Software with Self-Update",
  "author": "Gaurav Softwares",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "production": "NODE_ENV=production node server.js",
    "desktop": "node scripts/electron-dev.js",
    "electron": "cross-env ELECTRON_START_SERVER=1 electron .",
    "generate-icon": "node scripts/generate-icon.js",
    "predist": "node scripts/generate-icon.js && node scripts/prebuild-dist.js",
    "dist": "electron-builder",
    "dist:fresh": "node scripts/generate-icon.js && electron-builder --config.directories.output=build-out && node scripts/copy-env-to-dist.js",
    "postdist": "node scripts/copy-env-to-dist.js",
    "copy-env": "node scripts/copy-env-to-dist.js",
    "copy-env-appdata": "node scripts/copy-env-to-appdata.js",
    "setup-db": "node scripts/setup-database.js",
    "migrate": "node scripts/run-migration.js",
    "fix-gaurav-password": "node scripts/fix-gaurav-password.js",
    "change-master-password": "node scripts/change-master-password.js",
    "migrate-sales-returns": "node migrate-sales-returns.js",
    "setup-env": "node setup-env.js",
    "backup-db": "node scripts/backup-database.js",
    "backup-cloud": "node scripts/cloud-backup.js",
    "restore-db": "node scripts/restore-database.js",
    "sync-db": "node scripts/sync-database.js",
    "update": "bash update.sh"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "fast-xml-parser": "^4.3.2",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.0.1",
    "wait-on": "^9.0.10"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.varasilvers.jewelry-estimation",
    "productName": "Vara Silvers",
    "copyright": "Copyright © ${author}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "electron.js",
      "electron-env.js",
      "server.js",
      "config/**/*",
      "middleware/**/*",
      "public/**/*",
      "migrations/**/*",
      "migrate-sales-returns.js",
      "package.json",
      "!public/uploads/**/*",
      "!**/*.md",
      "!kc-jewellers-web/**/*",
      "!deploy/**/*",
      "!scripts/**",
      "scripts/label-printer.js",
      "!dist/**/*",
      "!.env"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "node_modules/bcrypt/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vara Silvers",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "GauravSolanki123456789",
        "repo": "VaraSilvers-JewelryEstimation",
        "private": true
      }
    ]
  }
}
